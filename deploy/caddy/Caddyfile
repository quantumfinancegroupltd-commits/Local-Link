# Domain first: Let's Encrypt for these hostnames
locallink.agency, www.locallink.agency {
  encode zstd gzip
  # Force no cache for HTML so deploys show immediately (no "Build ... UTC" stuck)
  header / Cache-Control "no-cache, no-store, must-revalidate"
  header / Pragma "no-cache"
  header / Expires "0"
  reverse_proxy 127.0.0.1:8080
}

# Catch-all: IP and any other host get internal cert on demand (e.g. https://140.238.93.79).
# Browsers will show a certificate warning for the IP; user can proceed.
https:// {
  tls internal {
    on_demand
  }
  encode zstd gzip
  reverse_proxy 127.0.0.1:8080
}


