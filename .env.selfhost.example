# Copy this to .env on the server (same directory as docker-compose.selfhost.yml).
# Do not commit .env — it is gitignored.
# Generate strong values, e.g.: openssl rand -hex 32

# If you use Supabase (or another external DB), set this. Otherwise the API uses the local Docker Postgres (db:5432).
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxx.supabase.co:5432/postgres

JWT_SECRET=
ADMIN_BOOTSTRAP_SECRET=
