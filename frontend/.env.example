# Optional: API base URL (used at build time).
# - Unset or /api: same-origin (e.g. site and API on same domain).
# - For production on a different API host, set to the full API base, e.g.:
#   VITE_API_BASE_URL=https://api.locallink.agency/api
#
# VITE_API_BASE_URL=

# Optional: Google Maps / Places (Marketplace map, location picker). Used at build time.
# Create .env from this file and set your key. deploy_mac.sh full copies frontend/.env to the server so the key is embedded in the build.
# VITE_GOOGLE_MAPS_API_KEY=
